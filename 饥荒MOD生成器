def safe_json_parse(text):
    """防止LLM返回非标准JSON导致崩溃"""
    try:
        return json.loads(text)
    except:
        # 尝试截取 JSON
        start = text.find("{")
        end = text.rfind("}") + 1

        if start != -1 and end != -1:
            try:
                return json.loads(text[start:end])
            except:
                pass

    # 最终兜底
    return {
        "concept": "解析失败",
        "entity": "Unknown Boss",
        "mechanics": [],
        "questions": ["请重新描述你的需求"]
    }


